# Root environment template for local Docker/dev setup
# Copy to .env and replace placeholder values.

POSTGRES_DB=banknova
POSTGRES_USER=banknova_user
POSTGRES_PASSWORD=change_me_secure_password
JWT_SECRET=change_me_super_long_random_secret_64_chars_minimum
SPRING_PROFILES_ACTIVE=docker
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SERVER_PORT=8080
